# Server
PORT=3000
NODE_ENV=development

# Database
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskmaster_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_LOGGING=false

# JWT
JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=7d

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Optional: WebSocket
ENABLE_WEBSOCKETS=false
